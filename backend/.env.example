# =============================================================================
# FitAI Backend -- Environment Variables Template
# Copy this file to .env and fill in your real credentials.
#   Windows:  copy .env.example .env
#   Linux/Mac: cp .env.example .env
#
# IMPORTANT: Never commit .env to GitHub. It is listed in .gitignore.
# =============================================================================

# -- IBM Watsonx.ai Credentials -----------------------------------------------
# Get your API key from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=YOUR_IBM_API_KEY

# Get your Project ID from: https://dataplatform.cloud.ibm.com
# -> Open project -> Manage -> General -> Project ID
IBM_PROJECT_ID=YOUR_PROJECT_ID

# Watsonx.ai service URL for your region:
#   Frankfurt (eu-de):    https://eu-de.ml.cloud.ibm.com
#   Dallas    (us-south): https://us-south.ml.cloud.ibm.com
#   Sydney    (au-syd):   https://au-syd.ml.cloud.ibm.com
#   London    (eu-gb):    https://eu-gb.ml.cloud.ibm.com
#   Tokyo     (jp-tok):   https://jp-tok.ml.cloud.ibm.com
IBM_URL=https://eu-de.ml.cloud.ibm.com

# -- Model Selection ----------------------------------------------------------
# IBM Granite model (eu-de, verified 2025):
WATSONX_MODEL_ID=ibm/granite-4-h-small

# -- Flask Configuration ------------------------------------------------------
FLASK_SECRET_KEY=change-this-to-a-long-random-string-in-production
FLASK_DEBUG=True

# -- CORS ---------------------------------------------------------------------
# In production, set this to your Vercel frontend URL:
#   ALLOWED_ORIGINS=https://your-fitai-app.vercel.app
ALLOWED_ORIGINS=*

# -- Logging ------------------------------------------------------------------
# Set to false in production to suppress debug output
WATSONX_DEBUG=true

# -- Server Port --------------------------------------------------------------
PORT=5000
