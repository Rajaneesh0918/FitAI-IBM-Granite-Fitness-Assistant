# =============================================================================
# FitAI -- .gitignore
# Root-level: covers backend/ and frontend/ in one file.
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS -- never commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.*.local

# -----------------------------------------------------------------------------
# Python -- backend
# -----------------------------------------------------------------------------
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
__pycache__/
*.pyc
*.pyo
*.py[cod]
*$py.class
.Python
backend/build/
backend/dist/
backend/*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Node.js -- frontend
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.vite/
node_modules/
dist/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
fitai_debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# OS / Editor artefacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.bak
*.tmp
